# ==========================================
# 心镜·AIGC智能体平台 环境变量配置模板
# ==========================================
# 复制此文件为 .env 并填入实际值
# 第八届CCF开源创新大赛 · 国产开源GPU AI创新生态赛 任务三
# ==========================================

# ---- AI算力平台 ----
# 主平台选择: lingshu / gitee_ai / deepseek / local / custom
AI_PLATFORM=gitee_ai

# Lingshu-32B — 灵枢医疗大模型 (moark.com)
LINGSHU_API_KEY=your_lingshu_api_key
LINGSHU_BASE_URL=https://api.moark.com/v1
LINGSHU_MODEL=Qwen3-8B

# Gitee.AI (沐曦 MetaX GPU) - 国产开源GPU算力平台
GITEE_AI_API_KEY=your_gitee_ai_api_key_here
GITEE_AI_BASE_URL=https://api.gitee.ai/v1
GITEE_AI_MODEL=qwen2.5-7b-instruct

# DeepSeek - 国产大模型（备用）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 通用API Key（当各平台独立Key未设置时使用）
AI_API_KEY=

# 备用平台列表（主平台不可用时自动切换）
AI_FALLBACK_PLATFORMS=deepseek

# ---- 华为云OBS存储 ----
OBS_ENDPOINT=https://obs.cn-north-4.myhuaweicloud.com
OBS_BUCKET=psych-monitor
OBS_AK=your_obs_access_key
OBS_SK=your_obs_secret_key

# ---- 数据库 ----
DATABASE_URL=sqlite:///./data/psych.db

# ---- 服务 ----
SERVICE_NAME=心镜·AIGC智能体平台
SERVICE_VERSION=2.0.0
